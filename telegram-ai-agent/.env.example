# Telegram
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here
# Optional: separate service chat/group where internal lead cards will be sent.
# If empty, internal cards will be sent to the same group where the request came from.
MANAGER_CHAT_ID=

# OpenAI
OPENAI_API_KEY=put_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Google Sheets
GOOGLE_SHEET_ID=put_google_sheet_id_here
GOOGLE_SHEET_TAB=Leads
GOOGLE_SERVICE_ACCOUNT_EMAIL=put_service_account_email_here
# Keep escaped line breaks in .env. Do not commit a real private key.
GOOGLE_PRIVATE_KEY=put_google_private_key_here

# Bot behavior
BOT_REPLY_PREFIX=
COMPANY_MANAGER_NAME=Андрей
